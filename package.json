{
  "name": "fitai-studio",
  "productName": "FitAI Studio",
  "version": "1.0.0",
  "description": "FitAI Studio PC App",
  "main": "main.js",
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && node server.js",
    "start:frontend": "cd frontend && npm run dev",
    "electron": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.fitai.studio",
    "win": {
      "icon": "fitdb_icon.ico",
      "target": "nsis"
    },
    "files": [
      "main.js",
      "fitdb_icon.ico",
      "backend/**/*",
      "frontend/dist/**/*",
      "data/**/*",
      "images/**/*",
      "videos/**/*"
    ]
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mysql2": "^3.23.0",
    "yt-search": "^2.13.1"
  }
}
