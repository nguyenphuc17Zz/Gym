{
  "name": "fitai-studio",
  "productName": "FitAI Studio",
  "version": "1.0.0",
  "description": "FitAI Studio PC App",
  "main": "main.js",
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && node server.js",
    "start:frontend": "cd frontend && npm run dev",
    "electron": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.fitai.studio",
    "win": {
      "icon": "fitdb_icon.ico",
      "target": "nsis"
    },
    "files": [
      "main.js",
      "fitdb_icon.ico",
      "backend/**/*",
      "frontend/dist/**/*",
      "data/**/*",
      "images/**/*",
      "videos/**/*"
    ]
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3"
  }
}
